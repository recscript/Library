local HWF_CatchFish = {}
HWF_CatchFish.__index = HWF_CatchFish

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local TweenInf = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

function HWF_CatchFish.Init(config)
    local title = config.Title or "HWF UI"
    local self = setmetatable({}, HWF_CatchFish)
    
    local CoreGui = game:GetService("CoreGui")
    if CoreGui:FindFirstChild("HWF_MainUI") then
        CoreGui.HWF_MainUI:Destroy()
    end
    
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "HWF_MainUI"
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.Parent = CoreGui
    
    -- Icon mở nhanh
    self.MainButton = Instance.new("ImageButton")
    self.MainButton.Name = "HWF_Icon"
    self.MainButton.Size = UDim2.new(0, 45, 0, 45)
    self.MainButton.Position = UDim2.new(0, 15, 0.4, 0)
    self.MainButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    self.MainButton.Image = "rbxassetid://10723374244"
    self.MainButton.Parent = self.ScreenGui
    
    local UICorner = Instance.new("UICorner") UICorner.CornerRadius = UDim.new(1, 0) UICorner.Parent = self.MainButton
    local UIBorder = Instance.new("UIStroke") UIBorder.Color = Color3.fromRGB(0, 150, 255) UIBorder.Thickness = 1.5 UIBorder.Parent = self.MainButton

    -- Khung Main chính (Rộng 280px là vừa vặn và gọn gàng)
    self.MainFrame = Instance.new("Frame")
    self.MainFrame.Name = "HWF_Container"
    self.MainFrame.Size = UDim2.new(0, 280, 0, 240)
    self.MainFrame.Position = UDim2.new(0, 75, 0.4, -120)
    self.MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    self.MainFrame.Visible = false
    self.MainFrame.Parent = self.ScreenGui
    
    local MainCorner = Instance.new("UICorner") MainCorner.CornerRadius = UDim.new(0, 6) MainCorner.Parent = self.MainFrame
    local MainBorder = Instance.new("UIStroke") MainBorder.Color = Color3.fromRGB(45, 45, 45) MainBorder.Thickness = 1.2 MainBorder.Parent = self.MainFrame
    
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 32)
    Title.BackgroundTransparency = 1
    Title.Text = "  " .. title
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold Title.TextSize = 13 Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = self.MainFrame

    -- =========================================================================
    -- SIDEBAR CHỨA TAB (Đã chuyển sang bên PHẢI, thu nhỏ chiều rộng chỉ để chứa Icon)
    -- =========================================================================
    self.Sidebar = Instance.new("ScrollingFrame")
    self.Sidebar.Name = "TabSidebar"
    self.Sidebar.Size = UDim2.new(0, 38, 1, -42)
    self.Sidebar.Position = UDim2.new(1, -44, 0, 34) -- Đặt ở rìa phải UI
    self.Sidebar.BackgroundTransparency = 1
    self.Sidebar.ScrollBarThickness = 0
    self.Sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    self.Sidebar.Parent = self.MainFrame
    
    local SideLayout = Instance.new("UIListLayout")
    SideLayout.Padding = UDim.new(0, 6)
    SideLayout.SortOrder = Enum.SortOrder.LayoutOrder
    SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    SideLayout.Parent = self.Sidebar
    
    SideLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.Sidebar.CanvasSize = UDim2.new(0, 0, 0, SideLayout.AbsoluteContentSize.Y)
    end)

    -- Khung chứa các trang nội dung chuyển sang nằm bên TRÁI
    self.PageContainer = Instance.new("Frame")
    self.PageContainer.Name = "PageContainer"
    self.PageContainer.Size = UDim2.new(1, -56, 1, -42)
    self.PageContainer.Position = UDim2.new(0, 6, 0, 34) -- Đặt ở bên trái UI
    self.PageContainer.BackgroundTransparency = 1
    self.PageContainer.Parent = self.MainFrame

    self.Tabs = {}
    self.CurrentTab = nil

    self.MainButton.MouseButton1Click:Connect(function()
        self.MainFrame.Visible = not self.MainFrame.Visible
    end)
    
    -- Kéo thả di chuyển
    local dragging, dragStart, startPos
    self.MainButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = self.MainButton.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            self.MainButton.Position = newPos
            self.MainFrame.Position = UDim2.new(newPos.X.Scale, newPos.X.Offset + 60, newPos.Y.Scale, newPos.Y.Offset - 120)
        end
    end)
    
    return self
end

-- =========================================================================
-- HÀM TẠO TAB CHỈ CHỨA ICON (Bỏ hoàn toàn Text)
-- =========================================================================
function HWF_CatchFish:CreateTab(iconId)
    local tab = {}
    iconId = iconId or "rbxassetid://10734950309"
    
    -- Nút bấm Tab hình vuông nhỏ gọn
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(0, 32, 0, 32)
    TabBtn.BackgroundColor3 = Color3.fromRGB(30,30,30) -- Chưa chọn: Tab đen
    TabBtn.Text = "" -- Không ghi chữ
    TabBtn.Parent = self.Sidebar
    
    local TCorner = Instance.new("UICorner") TCorner.CornerRadius = UDim.new(0, 4) TCorner.Parent = TabBtn
    local TBorder = Instance.new("UIStroke") TBorder.Color = Color3.fromRGB(25, 25, 25) TBorder.Parent = TabBtn
    
    -- Icon được căn chính giữa nút Tab
    local Icon = Instance.new("ImageLabel")
    Icon.Size = UDim2.new(0, 18, 0, 18)
    Icon.AnchorPoint = Vector2.new(0.5, 0.5)
    Icon.Position = UDim2.new(0.5, 0, 0.5, 0)
    Icon.BackgroundTransparency = 1
    Icon.Image = iconId
    Icon.ImageColor3 = Color3.fromRGB(255, 255, 255) -- Chưa chọn: Icon trắng
    Icon.Parent = TabBtn
    
    -- Trang nội dung ScrollingFrame riêng bên trái
    local Page = Instance.new("ScrollingFrame")
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ScrollBarThickness = 2
    Page.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 255)
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    Page.Parent = self.PageContainer
    
    local ListLayout = Instance.new("UIListLayout")
    ListLayout.Padding = UDim.new(0, 8)
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Parent = Page
    
    ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 5)
    end)
    
    tab.Container = Page

    -- Hàm xử lý hiệu ứng chọn Tab
    local function Select()
        if self.CurrentTab == tab then return end
        
        -- Reset tab cũ về trạng thái Tab đen + Icon trắng
        if self.CurrentTab then
            TweenService:Create(self.CurrentTab.Button, TweenInf, {BackgroundColor3 = Color3.fromRGB(30,30,30)}):Play()
            TweenService:Create(self.CurrentTab.Border, TweenInf, {Color = Color3.fromRGB(25, 25, 25)}):Play()
            TweenService:Create(self.CurrentTab.Icon, TweenInf, {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            self.CurrentTab.Page.Visible = false
        end
        
        -- Kích hoạt Tab mới: Nút đổi màu xanh, Icon đổi sang màu đen
        self.CurrentTab = tab
        TweenService:Create(TabBtn, TweenInf, {BackgroundColor3 = Color3.fromRGB(0, 150, 255)}):Play()
        TweenService:Create(TBorder, TweenInf, {Color = Color3.fromRGB(0, 180, 255)}):Play()
        TweenService:Create(Icon, TweenInf, {ImageColor3 = Color3.fromRGB(10, 10, 10)}):Play()
        Page.Visible = true
    end
    
    TabBtn.MouseButton1Click:Connect(Select)
    
    tab.Button = TabBtn
    tab.Border = TBorder
    tab.Icon = Icon
    tab.Page = Page
    
    table.insert(self.Tabs, tab)
    
    if #self.Tabs == 1 then
        Select()
    end
    
    local customTab = {}
    function customTab:AddDivider(config)    self.Container = Page HWF_CatchFish.AddDivider(self, config) return customTab end
    function customTab:AddDropdown(config)   self.Container = Page HWF_CatchFish.AddDropdown(self, config) return customTab end
    function customTab:AddToggle(config)     self.Container = Page HWF_CatchFish.AddToggle(self, config) return customTab end
    function customTab:AddButton(config)     self.Container = Page HWF_CatchFish.AddButton(self, config) return customTab end
    function customTab:AddSlider(config)     self.Container = Page HWF_CatchFish.AddSlider(self, config) return customTab end
    
    return customTab
end


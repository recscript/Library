function HWF_CatchFish:AddDropdown(config)
    local name = config.Name or "Dropdown"
    local options = config.Options or {}
    local default = config.Default or ""
    local callback = config.Callback or function() end
    
    local DropFrame = Instance.new("Frame")
    DropFrame.Size = UDim2.new(1, -4, 0, 32) DropFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15) DropFrame.ClipsDescendants = true DropFrame.Parent = self.Container
    
    local Corner = Instance.new("UICorner") Corner.CornerRadius = UDim.new(0, 4) Corner.Parent = DropFrame
    local Border = Instance.new("UIStroke") Border.Color = Color3.fromRGB(35, 35, 35) Border.Parent = DropFrame
    
    local DropBtn = Instance.new("TextButton")
    DropBtn.Size = UDim2.new(1, 0, 0, 32) DropBtn.BackgroundTransparency = 1
    DropBtn.Text = "  " .. name .. ": " .. default DropBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
    DropBtn.Font = Enum.Font.Gotham DropBtn.TextSize = 12 DropBtn.TextXAlignment = Enum.TextXAlignment.Left DropBtn.Parent = DropFrame
    
    local Arrow = Instance.new("TextLabel")
    Arrow.Size = UDim2.new(0, 20, 0, 20) Arrow.BackgroundTransparency = 1 Arrow.Text = "▶" Arrow.TextColor3 = Color3.fromRGB(120, 120, 120)
    Arrow.Font = Enum.Font.Gotham Arrow.TextSize = 25 Arrow.AnchorPoint = Vector2.new(0.5, 0.5) Arrow.Position = UDim2.new(0.91, 0, 0.42, 0) Arrow.Parent = DropBtn
    
    local ListContainer = Instance.new("ScrollingFrame")
    ListContainer.Size = UDim2.new(1, -10, 0, 84) ListContainer.Position = UDim2.new(0, 5, 0, 34)
    ListContainer.BackgroundColor3 = Color3.fromRGB(20, 20, 20) ListContainer.CanvasSize = UDim2.new(0, 0, 0, #options * 26)
    ListContainer.ScrollBarThickness = 2 ListContainer.Parent = DropFrame
    local LBorder = Instance.new("UIStroke") LBorder.Color = Color3.fromRGB(40, 40, 40) LBorder.Parent = ListContainer
    local LLayout = Instance.new("UIListLayout") LLayout.SortOrder = Enum.SortOrder.LayoutOrder LLayout.Parent = ListContainer
    
    local isOpen = false
    DropBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            TweenService:Create(Arrow, TweenInf, {Rotation = 90}):Play()
            TweenService:Create(DropFrame, TweenInf, {Size = UDim2.new(1, -4, 0, 124)}):Play()
        else
            TweenService:Create(Arrow, TweenInf, {Rotation = 0}):Play()
            TweenService:Create(DropFrame, TweenInf, {Size = UDim2.new(1, -4, 0, 32)}):Play()
        end
    end)
    
    local itemButtons = {}
    for _, v in ipairs(options) do
        local Item = Instance.new("TextButton")
        Item.Size = UDim2.new(1, 0, 0, 26) Item.BackgroundTransparency = 1
        Item.Text = "     " .. tostring(v) Item.TextColor3 = Color3.fromRGB(170, 170, 170)
        Item.Font = Enum.Font.Gotham Item.TextSize = 11 Item.TextXAlignment = Enum.TextXAlignment.Left Item.Parent = ListContainer
        
        local ActiveLine = Instance.new("Frame")
        ActiveLine.Size = UDim2.new(0, 3, 1, -4) ActiveLine.Position = UDim2.new(0, 4, 0, 2)
        ActiveLine.BackgroundColor3 = Color3.fromRGB(0, 150, 255) ActiveLine.BorderSizePixel = 0 ActiveLine.Visible = (v == default) ActiveLine.Parent = Item
        
        itemButtons[v] = ActiveLine
        Item.MouseButton1Click:Connect(function()
            DropBtn.Text = "  " .. name .. ": " .. tostring(v)
            for _, line in pairs(itemButtons) do line.Visible = false end
            ActiveLine.Visible = true callback(v)
        end)
    end
    return self
end


-- COMPONENT: DIVIDER THÔNG MINH
---------------------------------------------------------------------------
function HWF_CatchFish:AddDivider(config)
    local text = config.Text or "SECTION"
    local DivFrame = Instance.new("Frame")
    DivFrame.Size = UDim2.new(1, -4, 0, 16) DivFrame.BackgroundTransparency = 1 DivFrame.Parent = self.Container
    
    local HLayout = Instance.new("UIListLayout")
    HLayout.FillDirection = Enum.FillDirection.Horizontal HLayout.SortOrder = Enum.SortOrder.LayoutOrder
    HLayout.VerticalAlignment = Enum.VerticalAlignment.Center HLayout.Padding = UDim.new(0, 8) HLayout.Parent = DivFrame
    
    local Label = Instance.new("TextLabel")
    Label.BackgroundTransparency = 1 Label.Text = text Label.TextColor3 = Color3.fromRGB(120, 120, 120)
    Label.Font = Enum.Font.GothamBold Label.TextSize = 10 Label.LayoutOrder = 1
    
    Label.Size = UDim2.new(0, Label.TextBounds.X + 4, 1, 0)
    Label:GetPropertyChangedSignal("TextBounds"):Connect(function() Label.Size = UDim2.new(0, Label.TextBounds.X + 4, 1, 0) end)
    Label.Parent = DivFrame
    
    local Line = Instance.new("Frame")
    Line.BackgroundColor3 = Color3.fromRGB(35, 35, 35) Line.BorderSizePixel = 0 Line.LayoutOrder = 2 Line.Parent = DivFrame
    
    local function updateLineSize()
        local remainingWidth = DivFrame.AbsoluteSize.X - (Label.AbsoluteSize.X + HLayout.Padding.Offset)
        Line.Size = UDim2.new(0, remainingWidth > 0 and remainingWidth or 0, 0, 1)
    end
    DivFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateLineSize)
    Label:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateLineSize)
    task.spawn(updateLineSize)
    return self
end


    -- [[ 1. THÀNH PHẦN SLIDER HOÀN CHỈNH + Ô NHẬP SỐ TRỰC TIẾP ]] --
    local function AddSlider(parentPage, text, min, max, startVal)
        local Frame = Instance.new("Frame")
        local Corner = Instance.new("UICorner")
        local Stroke = Instance.new("UIStroke")
        local Label = Instance.new("TextLabel")
        local SliderButton = Instance.new("TextButton") 
        local SliderFill = Instance.new("Frame")
        local SquareKnob = Instance.new("Frame") 
        local ValueBox = Instance.new("TextBox")
        local BoxCorner = Instance.new("UICorner")
        local BoxStroke = Instance.new("UIStroke")

        Frame.Size = UDim2.new(1, 0, 0, 50)
        Frame.BackgroundColor3 = Theme.ElementBg
        Frame.ZIndex = 15
        Frame.Parent = parentPage
        
        Corner.CornerRadius = UDim.new(0, 5)
        Corner.Parent = Frame
        Stroke.Color = Theme.Border
        Stroke.Parent = Frame
        
        Label.Size = UDim2.new(0.5, 0, 0, 22)
        Label.Position = UDim2.new(0, 12, 0, 4)
        Label.BackgroundTransparency = 1
        Label.Text = text
        Label.TextColor3 = Theme.TextMain
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 12
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.ZIndex = 16
        Label.Parent = Frame
        
        -- Ô hiển thị số nhỏ bên ngón tay chỉ (Cho phép bấm vào gõ số)
        ValueBox.Size = UDim2.new(0, 45, 0, 20)
        ValueBox.Position = UDim2.new(1, -57, 0, 6)
        ValueBox.BackgroundColor3 = Theme.Sidebar
        ValueBox.Text = tostring(startVal)
        ValueBox.TextColor3 = Theme.MainAccent
        ValueBox.Font = Enum.Font.Code
        ValueBox.TextSize = 11
        ValueBox.ZIndex = 17
        ValueBox.ClearTextOnFocus = false
        ValueBox.Parent = Frame

        BoxCorner.CornerRadius = UDim.new(0, 4)
        BoxCorner.Parent = ValueBox
        BoxStroke.Color = Theme.Border
        BoxStroke.Parent = ValueBox
        
        SliderButton.Size = UDim2.new(1, -24, 0, 4)
        SliderButton.Position = UDim2.new(0, 12, 1, -12)
        SliderButton.BackgroundColor3 = Color3.fromRGB(50, 50, 52)
        SliderButton.Text = ""
        SliderButton.AutoButtonColor = false
        SliderButton.ZIndex = 16
        SliderButton.Parent = Frame
        
        local SBCorner = Instance.new("UICorner")
        SBCorner.CornerRadius = UDim.new(1,0)
        SBCorner.Parent = SliderButton
        
        SliderFill.Size = UDim2.new((startVal - min) / (max - min), 0, 1, 0)
        SliderFill.BackgroundColor3 = Theme.MainAccent
        SliderFill.ZIndex = 17
        SliderFill.Parent = SliderButton
        
        SquareKnob.Size = UDim2.new(0, 10, 0, 10)
        SquareKnob.Position = UDim2.new(1, -5, 0.5, -5)
        SquareKnob.BackgroundColor3 = Theme.White
        SquareKnob.BorderSizePixel = 0
        SquareKnob.ZIndex = 18
        SquareKnob.Parent = SliderFill

        local function UpdateSliderFromPercent(percentage)
            percentage = math.clamp(percentage, 0, 1)
            SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
            local RealValue = math.floor(min + (max - min) * percentage)
            ValueBox.Text = tostring(RealValue)
        end

        local IsDragging = false
        SliderButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                IsDragging = true
                local Percentage = (input.Position.X - SliderButton.AbsolutePosition.X) / SliderButton.AbsoluteSize.X
                UpdateSliderFromPercent(Percentage)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if IsDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local Percentage = (input.Position.X - SliderButton.AbsolutePosition.X) / SliderButton.AbsoluteSize.X
                UpdateSliderFromPercent(Percentage)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                IsDragging = false
            end
        end)

        ValueBox.FocusLost:Connect(function()
            local GivenNum = tonumber(ValueBox.Text)
            if not GivenNum then GivenNum = min end
            GivenNum = math.clamp(GivenNum, min, max)
            ValueBox.Text = tostring(GivenNum)
            local NewPercent = (GivenNum - min) / (max - min)
            SliderFill.Size = UDim2.new(NewPercent, 0, 1, 0)
        end)

        table.insert(AllElements, {Name = text, Frame = Frame})
    end


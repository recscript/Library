        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.ZIndex = 16
        Label.Parent = Frame
        
        -- Ép cứng kích thước hộp bấm (Rộng 160px, Cao 26px) cố định, không bao giờ lo bị thu nhỏ thành chấm đen!

        DropBtn.Position = UDim2.new(1, -172, 0.5, -13)
        DropBtn.BackgroundColor3 = Theme.Sidebar
        DropBtn.Text = ""
        DropBtn.ZIndex = 20
        DropBtn.Parent = Frame
        
        local DBCorner = Instance.new("UICorner")
        DBCorner.CornerRadius = UDim.new(0, 4)
        DBCorner.Parent = DropBtn
        local DBStroke = Instance.new("UIStroke")
        DBStroke.Color = Theme.Border
        DBStroke.Parent = DropBtn
        
        DropText.Size = UDim2.new(1, -10, 1, 0)
        DropText.Position = UDim2.new(0, 5, 0, 0)
        DropText.BackgroundTransparency = 1
        DropText.Text = (isMultiSelect and "Đã chọn (0)  ▼" or options[1] .. "  ▼")
        DropText.TextColor3 = Theme.TextMain
        DropText.Font = Enum.Font.Gotham
        DropText.TextSize = 11
        DropText.TextXAlignment = Enum.TextXAlignment.Right
        DropText.ZIndex = 21
        DropText.Parent = DropBtn

        -- Khung chứa danh sách được đẩy ra layer độc lập, ZIndex cực cao để đè lên mọi vật cản bên dưới
        local DropContainer = Instance.new("Frame")
        local DropList = Instance.new("UIListLayout")
        DropContainer.Size = UDim2.new(1, 0, 0, 0)
        DropContainer.Position = UDim2.new(0, 0, 1, 3)
        DropContainer.BackgroundColor3 = Theme.Sidebar
        DropContainer.Visible = false
        DropContainer.ZIndex = 999
        DropContainer.Parent = DropBtn
        
        local DCCorner = Instance.new("UICorner")
        DCCorner.CornerRadius = UDim.new(0, 4)
        DCCorner.Parent = DropContainer
        local DCStroke = Instance.new("UIStroke")
        DCStroke.Color = Theme.MainAccent
        DCStroke.Parent = DropContainer
        
        DropList.Parent = DropContainer
        DropList.SortOrder = Enum.SortOrder.LayoutOrder

        local IsOpen = false
        local dropdownData = {
            Close = function()
                IsOpen = false
                DropContainer.Visible = false
                Frame.ZIndex = 15
                DropBtn.ZIndex = 20
                DropContainer.Size = UDim2.new(1, 0, 0, 0)
            end,
            ID = uniqueID
        }
        DropdownRegistry[uniqueID] = dropdownData

        DropBtn.MouseButton1Click:Connect(function()
            IsOpen = not IsOpen
            if IsOpen then
                -- Logic Độc Quyền: Thằng này mở thì toàn bộ các thằng khác buộc đóng
                for id, data in pairs(DropdownRegistry) do if id ~= uniqueID then data.Close() end end
                Frame.ZIndex = 200
                DropBtn.ZIndex = 201
                DropContainer.Size = UDim2.new(1, 0, 0, #options * 26)
                DropContainer.Visible = true
            else
                dropdownData.Close()
            end
        end)

        local SelectedOptions = {}
        for _, optName in pairs(options) do
            local OptBtn = Instance.new("TextButton")
            OptBtn.Size = UDim2.new(1, 0, 0, 26)
            OptBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
            OptBtn.BackgroundTransparency = 1
            OptBtn.Text = "  " .. optName
            OptBtn.TextColor3 = Theme.TextDark
            OptBtn.Font = Enum.Font.Gotham
            OptBtn.TextSize = 11
            OptBtn.TextXAlignment = Enum.TextXAlignment.Left
            OptBtn.ZIndex = 1000
            OptBtn.Parent = DropContainer

            OptBtn.MouseButton1Click:Connect(function()
                if not isMultiSelect then
                    DropText.Text = optName .. "  ▼"
                    dropdownData.Close()
                else
                    if SelectedOptions[optName] then
                        SelectedOptions[optName] = nil
                        OptBtn.TextColor3 = Theme.TextDark
                    else
                        SelectedOptions[optName] = true
                        OptBtn.TextColor3 = Theme.MainAccent
                    end
                    local Count = 0
                    for _ in pairs(SelectedOptions) do Count = Count + 1 end
                    DropText.Text = "Đã chọn ("..tostring(Count)..")  ▼"
                end
